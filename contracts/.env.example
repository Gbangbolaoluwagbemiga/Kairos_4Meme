## Contracts (Foundry) — example env
## Copy to `.env` before deploying/registering.

# BNB Chain testnet RPC
FOURMEME_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545

# Deployer private key (testnet only)
PRIVATE_KEY=

# Optional admin for contract ownership (defaults to deployer)
KAIROS_ADMIN=

# After deploy, export these for register script:
KAIROS_AGENT_REGISTRY=
KAIROS_SPENDING_POLICY=

# Optional: app-style names (RegisterAgents accepts these too)
KAIROS_AGENT_REGISTRY_EVM_ADDRESS=
KAIROS_SPENDING_POLICY_EVM_ADDRESS=

# Agent owners (payout recipients). For hackathon, you can set them all to the treasury address.
ORACLE_OWNER=
NEWS_OWNER=
YIELD_OWNER=
TOKENOMICS_OWNER=
PERP_OWNER=
PROTOCOL_OWNER=
BRIDGES_OWNER=
DEX_VOLUMES_OWNER=
CHAIN_SCOUT_OWNER=

# Agent wallets (public addresses). Used by `script/SetAgentOwners.s.sol`.
ORACLE_EVM_ADDRESS=
NEWS_EVM_ADDRESS=
YIELD_EVM_ADDRESS=
TOKENOMICS_EVM_ADDRESS=
PERP_EVM_ADDRESS=
PROTOCOL_EVM_ADDRESS=
BRIDGES_EVM_ADDRESS=
DEX_VOLUMES_EVM_ADDRESS=
CHAIN_SCOUT_EVM_ADDRESS=

# Pricing & limits (native BNB wei)
KAIROS_DEFAULT_AGENT_PRICE_WEI=500000000000000 # 0.0005 BNB
KAIROS_DEFAULT_DAILY_LIMIT_WEI=0

