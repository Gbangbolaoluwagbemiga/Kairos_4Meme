## Kairos Backend (Four.meme AI Sprint build) — example env
## Copy to `.env` and fill values.
##
## IMPORTANT:
## - Never commit your real `.env`
## - `FOURMEME_TREASURY_PRIVATE_KEY` controls funds on-chain (testnet BNB here)

# --- AI (Groq) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- BNB Chain testnet (EVM) ---
# You can provide multiple RPCs as a comma-separated list for automatic failover.
FOURMEME_RPC_URLS=https://data-seed-prebsc-1-s1.binance.org:8545
FOURMEME_CHAIN_ID=97

# Treasury private key (0x-prefixed or not). REQUIRED for faucet + treasury→agent payouts.
FOURMEME_TREASURY_PRIVATE_KEY=

# Deployed contract addresses (Sprint testnet)
KAIROS_AGENT_REGISTRY_EVM_ADDRESS=
# Optional; leave blank to disable spending policy gating
KAIROS_SPENDING_POLICY_EVM_ADDRESS=

# Safer defaults for hackathon demos
KAIROS_FAST_MODE=1
KAIROS_DEFAULT_AGENT_PRICE_BNB=0.0005
KAIROS_A2A_PRICE_BNB=0.00025
KAIROS_TREASURY_TX_WAIT_CONFIRMS=1
KAIROS_A2A_TX_WAIT_CONFIRMS=1
KAIROS_TX_WAIT_TIMEOUT_MS=180000
FOURMEME_RPC_TIMEOUT_MS=5000
FOURMEME_RPC_CACHE_TTL_MS=30000

# If set to 1, a revert in canSpend() blocks payout. Default 0 = pay anyway if policy ABI/deploy is mismatched.
KAIROS_SPENDING_POLICY_STRICT=0

# --- Optional: live web search grounding ---
# Set one of these for live web; otherwise Kairos will be explicit that it's offline for web queries.
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=
KAIROS_WEB_SEARCH_PROVIDER=auto

# --- Optional: CoinGecko (avoid public rate limits) ---
COINGECKO_API_KEY=

# --- Optional: Supabase (telemetry + chat persistence) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=

# --- Server ---
PORT=3001
STRICT_CORS=0
ALLOWED_ORIGINS=http://localhost:5173

# --- Agent addresses (EVM) ---
# If you deployed/register agents on-chain, Kairos can read them from AgentRegistry.
# These env addresses remain as fallback and are also used by some UI and payment paths.
ORACLE_EVM_ADDRESS=
NEWS_EVM_ADDRESS=
YIELD_EVM_ADDRESS=
TOKENOMICS_EVM_ADDRESS=
PERP_EVM_ADDRESS=
CHAIN_SCOUT_EVM_ADDRESS=
PROTOCOL_EVM_ADDRESS=
BRIDGES_EVM_ADDRESS=
DEX_VOLUMES_EVM_ADDRESS=

# --- Optional: agent private keys for true A2A transfers (NEVER COMMIT REAL KEYS) ---
# ORACLE_PRIVATE_KEY=
# NEWS_PRIVATE_KEY=
# ...
